// Schema pronto para SQLite (dev/local) e Postgres/Supabase (produção).
// Para produção: troque provider para "postgresql" e use a DATABASE_URL do Supabase.

datasource db {
  provider = "sqlite" // troque para "postgresql" em produção
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum LeadStatus {
  NOVO
  CONTACTADO
  EM_NEGOCIACAO
  CONVERTIDO
  PERDIDO
}

model Lead {
  id            String     @id @default(cuid())
  firstName     String
  lastName      String
  email         String
  whatsapp      String
  scheduledDate DateTime
  status        LeadStatus @default(NOVO)
  notes         Note[]
  source        String?    @default("landing-page")
  ip            String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([status])
  @@index([scheduledDate])
  @@index([createdAt])
}

model Note {
  id        String   @id @default(cuid())
  content   String
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
}
